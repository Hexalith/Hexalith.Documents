<Project Sdk="Microsoft.NET.Sdk">
	<PropertyGroup>
		<TargetFramework>$(CommonTargetFrameworks)</TargetFramework>
		<NoWarn>$(NoWarn);CA1716;</NoWarn>
	</PropertyGroup>
	<ItemGroup Condition="'$(UseProjectReference)' == 'true'">
		<ProjectReference Include="$(HexalithPath)src\Core\UI\Hexalith.UI.Components.Abstractions\Hexalith.UI.Components.Abstractions.csproj" />
	</ItemGroup>
	<ItemGroup Condition="'$(UseProjectReference)' != 'true'">
		<PackageReference Include="Hexalith.UI.Components.Abstractions" Version="$(HexalithVersion)" />
	</ItemGroup>
	<ItemGroup>
	  <ProjectReference Include="$(HexalithDocumentsPath)src\Application\Hexalith.Documents.Application\Hexalith.Documents.Application.csproj" />
	  <ProjectReference Include="$(HexalithDocumentsPath)src\Application\Hexalith.Documents.Commands\Hexalith.Documents.Commands.csproj" />
	  <ProjectReference Include="$(HexalithDocumentsPath)src\Domain\Hexalith.Documents.Domain\Hexalith.Documents.Domain.csproj" />
	  <ProjectReference Include="$(HexalithDocumentsPath)src\Domain\Hexalith.Documents.Events\Hexalith.Documents.Events.csproj" />
	</ItemGroup>
</Project>
