@page "/Document/Document"
@inject NavigationManager NavigationManager;
@using Labels = Hexalith.Documents.Shared.Resources.Documents.Pages.DocumentIndex;
@using Hexalith.Documents.Shared.Documents.Components
<FluentToolbar Style="width:100%;">
    <FluentButton IconStart="@(new Icons.Filled.Size16.Add())" OnClick="AddAsync">@Labels.Add</FluentButton>
</FluentToolbar>

<FluentStack Orientation="Orientation.Vertical">
    <h3>@Labels.Title</h3>
    <DocumentSummaryGrid/>
</FluentStack>

@code {

    private void AddAsync()
	{
		NavigationManager.NavigateTo("/Document/Document/Add");
	}
}