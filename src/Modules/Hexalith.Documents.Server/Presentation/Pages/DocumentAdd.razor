@page "/Document/Document/Add"
@inject IFileService FileService
@inject NavigationManager NavigationManager
@inject IStringLocalizer<DocumentAdd> L
@inject IClientCommandService CommandService
@using Hexalith.Application.Services
@using Hexalith.Infrastructure.ClientApp.Services
@using Labels = Hexalith.Documents.Server.Resources.Documents.Pages.DocumentAdd
@using Hexalith.Documents.Commands

<FluentStack Orientation="Orientation.Vertical" Style="padding:20px;">
	<h3>@Labels.Title</h3>
	@if (data is not null)
	{
		<FluentStack Width="100%" Style="padding:15px" Orientation="Orientation.Vertical">
			<FluentGrid Style="width:100%">
				<FluentGridItem xs="12" sm="12" lg="3">
					<FluentTextField Style="width:100%;" @bind-Value="data.Id" Label="@Labels.Id"></FluentTextField>
				</FluentGridItem>
				<FluentGridItem xs="12" sm="12" lg="3">
					<FluentTextField Style="width:100%;" @bind-Value="data.Name" Label="@Labels.Name"></FluentTextField>
				</FluentGridItem>
				<FluentGridItem xs="12" sm="12" lg="12">
					<FluentTextArea Style="width:100%;" @bind-Value="data.Description" Label="@Labels.Comments"></FluentTextArea>
				</FluentGridItem>
			</FluentGrid>
			<FluentSpacer />
			<FluentButton Appearance="Appearance.Accent" IconStart="@(new Icons.Regular.Size24.Save())" OnClick="OnSave">@Labels.Save</FluentButton>
		</FluentStack>
	}
</FluentStack>

@code {
	ViewModels.DocumentAdd data = new();

	public async Task OnSave()
	{
		await CommandService.SendCommandAsync(new CreateDocument(
				data.Id,
				data.Name,
				data.Description,
				new Uri("file://my-document.pdf"),
				"user1",
				DateTimeOffset.Now,
				null),
			CancellationToken.None);
		NavigationManager.NavigateTo("/Document/Document");
	}

}
