@using Hexalith.Extensions.Helpers
@inject IToastService ToastService
@if (Items is not null)
{
    <FluentDataGrid GenerateHeader="GenerateHeaderOption.Sticky"
                    Items="Items"
                    ItemKey="@((i) => i.Id)"
                    TGridItem="FileTypeSummaryViewModel"
                    ResizableColumns="true"
                    ShowHover="true"
                    OnRowDoubleClick="OnRowDoubleClick">
        <PropertyColumn Title="@Labels.Id" Property="@(p => p.Id)" Sortable="true" />
        <PropertyColumn Title="@Labels.Name" Property="@(p => p.Name)" Sortable="true" />
        <TemplateColumn Title="@Labels.Disabled">
            <FluentCheckbox Value="@(context.Disabled)" ValueChanged="@(c => DisabledChanged(context.Id, c))" />
        </TemplateColumn>
    </FluentDataGrid>
}

@code {

    [Parameter]
    public bool ShowDisabledItems { get; set; }

    [Parameter]
    [EditorRequired]
    public required IQueryable<FileTypeSummaryViewModel> Items { get; set; }

    [Parameter]
    public EventCallback<FileTypeSummaryViewModel> OnDisabledChanged { get; set; }

    [Parameter]
    public EventCallback<FileTypeSummaryViewModel> OnSummaryDoubleClick { get; set; }

    private void OnRowDoubleClick(FluentDataGridRow<FileTypeSummaryViewModel> row)
    {
        if (row.Item is not null)
        {
            OnSummaryDoubleClick.InvokeAsync(row.Item);
        }
    }

    private void DisabledChanged(string id, bool disabled)
    {
        var item = Items?.FirstOrDefault(p => p.Id == id);
        if (item is null || item.Disabled == disabled)
        {
            return;
        }
        try
        {
            OnDisabledChanged.InvokeAsync(item with { Disabled = disabled });
        }
        catch (Exception ex)
        {
            ToastService.ShowError(string.Format(Labels.UpdateError, ex.FullMessage()));
        }
    }

}